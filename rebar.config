{erl_opts, [debug_info]}.

{deps, [
    ranch,
    {enoise, {git, "https://github.com/aeternity/enoise.git", {branch, "master"}}}
]}.

{project_plugins, [
    rebar3_hex,
    rebar3_ex_doc
]}.

{ex_doc, [
    {main, <<"README.md">>},
    {source_url, <<"https://github.com/longlene/ranch_noise">>}
]}.

{hex, [{doc, #{provider => ex_doc}}]}.
